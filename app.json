{
  "expo": {
    "name": "Häkel Tracker",
    "slug": "haekel-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.serpantsophia.haekeltracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Wird zum Scannen von Barcodes und Aufnehmen von Materialfotos benötigt.",
        "NSPhotoLibraryUsageDescription": "Wird zum Hinzufügen von Materialfotos aus der Galerie benötigt."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.serpantsophia.haekeltracker",
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Häkel Tracker",
      "shortName": "Häkel",
      "description": "Häkel & Strick Auftrags-Tracker",
      "themeColor": "#7C4DFF",
      "backgroundColor": "#ffffff",
      "publicPath": "/haekel-tracker"
    },
    "extra": {
      "eas": {
        "projectId": "7b31bf96-826c-40d7-93d2-3b8a891ded66"
      }
    },
    "owner": "serpantsophia"
  }
}
